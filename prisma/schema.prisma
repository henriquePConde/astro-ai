// Prisma schema for Astro AI


generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}
        

model User {
	id    String  @id @db.Uuid
	email String  @unique
	name  String?
  @@map("users")
}


