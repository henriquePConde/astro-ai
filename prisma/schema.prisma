// Prisma schema for Astro AI

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String             @id @db.Uuid
  email     String             @unique
  name      String?
  createdAt DateTime           @default(now())
  reports   Report[]
  charts    Chart[]
  messages  InterpretMessage[]
  reportJobs ReportJob[]

  @@map("users")
}

model Report {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  personName String   @map("person_name")
  birthData  Json     @map("birth_data")
  content    Json
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("reports")
}

model ReportJob {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  personName    String   @map("person_name")
  birthData     Json     @map("birth_data")
  status        String
  currentStep   Int      @default(0) @map("current_step")
  totalSteps    Int      @default(0) @map("total_steps")
  progress      Float    @default(0)
  errorMessage  String?  @map("error_message")
  partialContent Json?   @map("partial_content")
  meta          Json?    @map("meta")
  reportId      String?  @map("report_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("report_jobs")
}

model Chart {
  id               String             @id @default(uuid()) @db.Uuid
  userId           String             @map("user_id") @db.Uuid
  birthData        Json               @map("birth_data")
  calculatedData   Json?              @map("calculated_data") // Cached chart calculation result
  calculatedAt     DateTime?          @map("calculated_at")   // When the calculation was cached
  createdAt        DateTime           @default(now()) @map("created_at")
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages         InterpretMessage[]

  @@index([userId])
  @@index([createdAt])
  @@map("charts")
}

model InterpretMessage {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  chartId   String?  @map("chart_id") @db.Uuid
  message   String
  /// "user" for user prompt, "assistant" for AI reply
  role      String   @default("user")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  chart     Chart?   @relation(fields: [chartId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([chartId])
  @@index([createdAt])
  @@map("interpret_messages")
}
