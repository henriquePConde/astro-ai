    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "next": "15.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.2",
    "@supabase/ssr": "^0.5.0",
    "axios": "^1.6.7",
    "@tanstack/react-query": "^5.59.0",
    "@prisma/client": "^5.19.1",
    "@supabase/supabase-js": "^2.47.10"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.20.1",
    "eslint-config-next": "15.1.6",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.3.3",
    "typescript": "^5.6.0",
    "vitest": "^2.0.5",
    "prisma": "^5.19.1"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md}": [
