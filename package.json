{
  "name": "astro-ai-fullstack",
  "private": true,
  "version": "0.1.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "prisma generate && tsc -noEmit",
    "lint": "next lint",
    "test": "vitest run --passWithNoTests",
    "prepare": "husky install",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "gen:types": "dotenv -e .env -- npx supabase gen types typescript --db-url \"$DB_URL\" --schema public,auth,storage,graphql_public > src/types/supabase.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.3.22",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hookform/resolvers": "^5.2.2",
    "@mui/icons-material": "^7.3.5",
    "@mui/material": "^7.3.4",
    "@prisma/client": "^5.19.1",
    "@react-three/drei": "^10.0.7",
    "@react-three/fiber": "^9.1.2",
    "@supabase/ssr": "^0.5.0",
    "@supabase/supabase-js": "^2.47.10",
    "@tanstack/react-query": "^5.59.0",
    "ai": "^4.3.13",
    "axios": "^1.6.7",
    "d3": "^7.9.0",
    "date-fns-tz": "^3.2.0",
    "jsonwebtoken": "^9.0.2",
    "next": "15.1.6",
    "puppeteer": "^24.10.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.66.0",
    "react-markdown": "^10.1.0",
    "swisseph-v2": "^1.0.3",
    "three": "^0.176.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.11.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.176.0",
    "eslint": "^9.20.1",
    "eslint-config-next": "15.1.6",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.3.3",
    "prisma": "^5.19.1",
    "typescript": "^5.6.0",
    "vitest": "^2.0.5"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md}": [
      "prettier --write"
    ]
  }
}
