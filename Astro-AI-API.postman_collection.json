        {
          "name": "Interpret Chart",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response is text stream\", function () {",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('text/plain');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"message\": \"What does my Sun in Leo mean?\",\n    \"context\": {\n        \"planets\": [\n            {\n                \"name\": \"Sun\",\n                \"sign\": \"Leo\",\n                \"house\": 5,\n                \"position\": \"15° Leo\"\n            }\n        ],\n        \"aspects\": [\n            {\n                \"planet1\": \"Sun\",\n                \"planet2\": \"Moon\",\n                \"type\": \"trine\",\n                \"angle\": 120\n            }\n        ],\n        \"houses\": {\n            \"ascendant\": 10,\n            \"midheaven\": 20\n        }\n    },\n    \"chatHistory\": []\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/calculate/interpret",
              "host": ["{{baseUrl}}"],
              "path": ["api", "calculate", "interpret"]
            },
            "description": "AI-powered chart interpretation via streaming response. Requires authentication. Returns text/plain stream."
          },
          "response": []
        }
      ]
