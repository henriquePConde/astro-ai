    {
      "name": "Calculate",
      "item": [
        {
          "name": "Calculate Chart",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has chart data\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('success', true);",
                  "    pm.expect(jsonData.data).to.have.property('planets');",
                  "    pm.expect(jsonData.data).to.have.property('houses');",
                  "    pm.expect(jsonData.data).to.have.property('aspects');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"John Doe\",\n    \"year\": 1990,\n    \"month\": 5,\n    \"day\": 15,\n    \"hour\": 14,\n    \"minute\": 30,\n    \"city\": \"New York\",\n    \"nation\": \"United States\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/calculate",
              "host": ["{{baseUrl}}"],
              "path": ["api", "calculate"]
            },
            "description": "Calculates an astrological birth chart. Requires authentication. All fields except city and nation are required."
          },
          "response": []
        },
